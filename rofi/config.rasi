configuration {
    display-drun: "Apps";
    display-window: "Fenster: ";
    drun-display-format: "{icon} {name}";
    font: "Jetbrains mono Nerd Font Medium 15";
    modi: "window,run,drun";
    show-icons: true;
    icon-theme: "Papirus";
}

@import "~/.cache/wal/colors-rofi-dark.rasi"


* {
    padding: 0px;
    spacing: 0px;
    margin: 0px;
    border: 0px;
}

window {
   width: 500px;
   height: 250px;
   border: 2px;
   border-color: @foreground;
}

